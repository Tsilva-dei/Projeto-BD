@app.route('/dbproj/report/demand', methods=['GET'])
@admin_required
def report_demand():
    conn = db_connection()
    cur = conn.cursor()
    try:
        query = """
        SELECT h1.line_id, h1.time_slot, h1.validations
        FROM (
            SELECT
                viagem.linha_linhaid AS line_id,
                to_char(v.usadoa, 'HH24:00') || '-' || to_char(v.usadoa, 'HH24:59') AS time_slot,
                COUNT(*) AS validations
            FROM validacao v
            JOIN viagem ON v.viagem_viagemid = viagem.viagemid
            GROUP BY viagem.linha_linhaid, to_char(v.usadoa, 'HH24:00') || '-' || to_char(v.usadoa, 'HH24:59')
        ) h1
        WHERE h1.validations = (
            SELECT MAX(validations)
            FROM (
                SELECT COUNT(*) AS validations
                FROM validacao v2
                JOIN viagem v2_viagem ON v2.viagem_viagemid = v2_viagem.viagemid
                WHERE v2_viagem.linha_linhaid = h1.line_id
                GROUP BY to_char(v2.usadoa, 'HH24:00') || '-' || to_char(v2.usadoa, 'HH24:59')
            ) max_sq
        ) OR h1.validations = (
            SELECT MIN(validations)
            FROM (
                SELECT COUNT(*) AS validations
                FROM validacao v3
                JOIN viagem v3_viagem ON v3.viagem_viagemid = v3_viagem.viagemid
                WHERE v3_viagem.linha_linhaid = h1.line_id
                GROUP BY to_char(v3.usadoa, 'HH24:00') || '-' || to_char(v3.usadoa, 'HH24:59')
            ) min_sq
        )
        ORDER BY h1.line_id, h1.validations DESC
