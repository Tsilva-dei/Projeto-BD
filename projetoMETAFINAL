@app.route('/dbproj/wallet/topup', methods=['POST'])
def charge_wallet():
    # 1. Validar o Token e extrair o ID do utilizador
    token_header = flask.request.headers.get('Authorization')
    if not token_header:
        return flask.jsonify({"status": 401, "errors": "Token em falta"}), 401
    
    token = token_header.split(" ")[1] if "Bearer" in token_header else token_header
    try:
        data = jwt.decode(token, SECRET_KEY, algorithms=["HS256"])
        user_id = data['user_id']
        role = data['role']
        
        if role != 'client':
            return flask.jsonify({"status": 403, "errors": "Apenas clientes têm carteira digital"}), 403
            
    except:
        return flask.jsonify({"status": 401, "errors": "Token inválido"}), 401

    # 2. Obter o valor do carregamento
    p = flask.request.get_json()
    if 'valor' not in p or p['valor'] <= 0:
        return flask.jsonify({"status": 400, "errors": "Valor inválido"}), 400

    conn = db_connection()
    cur = conn.cursor()
    try:
        # 3. Atualizar o saldo na tabela cliente
        cur.execute("UPDATE cliente SET saldo = saldo + %s WHERE utilizador_utilizadorid = %s RETURNING saldo",
                    (p['valor'], user_id))
        novo_saldo = cur.fetchone()[0]

        # 4. Registar a transação para o histórico (exigido no modelo de dados)
        cur.execute("""
            INSERT INTO transacao (valor, tipotransacao, datatransacao, estado, cliente_utilizador_utilizadorid) 
            VALUES (%s, 'Carregamento', CURRENT_TIMESTAMP, 'Concluida', %s)
        """, (p['valor'], user_id))

        conn.commit()
        return flask.jsonify({"status": 200, "results": {"novo_saldo": float(novo_saldo)}}), 200
    except Exception as e:
        conn.rollback()
        return flask.jsonify({"status": 400, "errors": str(e)}), 400
    finally:
        conn.close()

