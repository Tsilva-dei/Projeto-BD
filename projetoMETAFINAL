@app.route('/dbproj/register/customer', methods=['POST'])
@admin_required
def register_client():
    p = flask.request.get_json()
    conn = db_connection()
    cur = conn.cursor()
    try:
        cur.execute("INSERT INTO utilizador (nome, email, palavrapasse) VALUES (%s,%s,%s) RETURNING utilizadorid",
                    (p['nome'], p['email'], p['password']))
        uid = cur.fetchone()[0]
        cur.execute("INSERT INTO cliente (saldo, nif, telemovel, idade, utilizador_utilizadorid) VALUES (0,%s,%s,%s,%s)",
                    (p['nif'], p['telemovel'], p['idade'], uid))
        conn.commit()
        return flask.jsonify({"status": 201, "results": "Cliente criado"}), 201
    except Exception as e:
        conn.rollback()
        return flask.jsonify({"status": 400, "errors": str(e)}), 400
    finally: conn.close()

