    try:
        # 2. Procurar a viagem correspondente à estação e à hora
        cur.execute("""
            SELECT v.viagemid
            FROM viagem v
            JOIN estacaolinha el ON v.linha_linhaid = el.linha_linhaid
            WHERE el.estacao_estacaoid = %s AND v.datapartida >= %s::timestamp
            ORDER BY v.datapartida ASC
            LIMIT 1
        """, (p['station_id'], p['used_at']))
        viagem = cur.fetchone()

        if not viagem:
            return flask.jsonify({"status": 400, "errors": "Nenhuma viagem disponível nesta estação"}), 400

        viagem_id = viagem[0]

        # 3. Registar a validação
        cur.execute("""
            INSERT INTO validacao (usadoa, estacao_estacaoid, bilhete_bilheteid, viagem_viagemid)
            VALUES (%s, %s, %s, %s)
        """, (p['used_at'], p['station_id'], ticket_id, viagem_id))

        # 4. Atualizar a ocupação do metro
        cur.execute("UPDATE viagem SET ocupacaoatual = ocupacaoatual + 1 WHERE viagemid = %s", (viagem_id,))

        conn.commit()
        return flask.jsonify({"status": 200, "errors": None}), 200

    except Exception as e:
        conn.rollback()
        return flask.jsonify({"status": 400, "errors": str(e)}), 400
    finally:
        conn.close()

@app.route('/dbproj/report/monthly', methods=['GET'])
@admin_required
def report_monthly():
    conn = db_connection()
    cur = conn.cursor()
    try:
        query = """
        SELECT
            t.line_id,
            t.month,
            COUNT(t.customer_id) AS active_customers,
            SUM(CASE WHEN t.validations >= 2 THEN 1 ELSE 0 END) AS repeat_customers
        FROM (
            SELECT
                viagem.linha_linhaid AS line_id,
                EXTRACT(MONTH FROM v.usadoa) AS month,
                compra.cliente_utilizador_utilizadorid AS customer_id,
                COUNT(v.validacaoid) AS validations
            FROM validacao v
            JOIN viagem ON v.viagem_viagemid = viagem.viagemid
            JOIN bilhete b ON v.bilhete_bilheteid = b.bilheteid
            JOIN compra ON b.compra_compraid = compra.compraid
            GROUP BY viagem.linha_linhaid, EXTRACT(MONTH FROM v.usadoa), compra.cliente_utilizador_utilizadorid
        ) t
        GROUP BY t.line_id, t.month
        ORDER BY t.line_id, t.month
        """
        cur.execute(query)
        results = [{"line_id": r[0], "month": int(r[1]), "active_customers": r[2], "repeat_customers": int(r[3])} for r in cur.fetchall()]
