## ENDPOINT 9 – WALLET TOPUP
## POST /dbproj/wallet/topup
## CORRIGIDO: FOR UPDATE antes de atualizar saldo
##########################################################

@app.route('/dbproj/wallet/topup', methods=['POST'])
@client_required
def charge_wallet():
    token = extract_token()
    data = jwt.decode(token, SECRET_KEY, algorithms=["HS256"])
    user_id = data['user_id']

    p = flask.request.get_json()
    amount = p.get('amount') or p.get('valor')
    if not amount or float(amount) <= 0:
        return flask.jsonify({"status": 400, "errors": "Valor inválido (campo: amount)"}), 400

    conn = None
    try:
        conn = db_connection()
        cur = conn.cursor()

        # Bloqueia a linha do cliente antes de alterar o saldo (evita race condition)
        cur.execute("""
            SELECT saldo FROM cliente
            WHERE utilizador_utilizadorid = %s
            FOR UPDATE
        """, (user_id,))

        if not cur.fetchone():
            return flask.jsonify({"status": 404, "errors": "Cliente não encontrado"}), 404

        cur.execute("""
            UPDATE cliente SET saldo = saldo + %s
            WHERE utilizador_utilizadorid = %s RETURNING saldo
        """, (amount, user_id))
        novo_saldo = cur.fetchone()[0]

        cur.execute("""
            INSERT INTO transacao (valor, tipotransacao, datatransacao, estado, cliente_utilizador_utilizadorid)
            VALUES (%s, 'Carregamento', CURRENT_TIMESTAMP, 'Concluida', %s)
        """, (amount, user_id))

        conn.commit()
        return flask.jsonify({"status": 200, "errors": None, "results": {"new_balance": float(novo_saldo)}}), 200

    except Exception as e:
        if conn:
            conn.rollback()
        return flask.jsonify({"status": 400, "errors": str(e)}), 400
    finally:
        if conn:
            conn.close()

