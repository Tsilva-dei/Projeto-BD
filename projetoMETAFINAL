## ENDPOINT 8 – LIST LINES AND UPCOMING DEPARTURES
## GET /dbproj/lines_next
##########################################################

@app.route('/dbproj/lines_next', methods=['GET'])
def get_lines_next():
    conn = None
    try:
        conn = db_connection()
        cur = conn.cursor()

        cur.execute("""
            SELECT
                l.linhaid,
                l.nome,
                origem.nome        AS origin_terminal,
                v.sentido          AS destination_terminal,
                v.datapartida,
                v.capacidademax - v.ocupacaoatual AS available_capacity
            FROM linha l
            JOIN viagem v ON l.linhaid = v.linha_linhaid
            JOIN (
                SELECT el.linha_linhaid, e.nome
                FROM estacaolinha el
                JOIN estacao e ON el.estacao_estacaoid = e.estacaoid
                WHERE el.ordem = (
                    SELECT MIN(el2.ordem)
                    FROM estacaolinha el2
                    WHERE el2.linha_linhaid = el.linha_linhaid
                )
            ) origem ON origem.linha_linhaid = l.linhaid
            WHERE v.datapartida = (
                SELECT MIN(v2.datapartida)
                FROM viagem v2
                WHERE v2.linha_linhaid = l.linhaid
                  AND v2.sentido = v.sentido
                  AND v2.datapartida >= CURRENT_TIMESTAMP
            )
            ORDER BY l.linhaid, v.sentido
        """)

        rows = cur.fetchall()
        results = []
        for row in rows:
            results.append({
                "line_id":              row[0],
                "line_name":            row[1],
                "origin_terminal":      row[2],
                "destination_terminal": row[3],
                "departure_time":       row[4].strftime("%Y-%m-%d %H:%M:%S"),
                "estimated_delay_min":  0,
                "available_capacity":   int(row[5])
            })

        return flask.jsonify({"status": 200, "errors": None, "results": results}), 200

    except Exception as e:
        return flask.jsonify({"status": 500, "errors": str(e)}), 500
    finally:
        if conn:
            conn.close()

