## ENDPOINT 10 – PURCHASE TICKET
## POST /dbproj/purchase
## CORRIGIDO: travel_date validado e verificado na BD
##########################################################

@app.route('/dbproj/purchase', methods=['POST'])
@client_required
def purchase_ticket():
    token = extract_token()
    data = jwt.decode(token, SECRET_KEY, algorithms=["HS256"])
    user_id = data['user_id']

    p = flask.request.get_json()
    required = ['line_id', 'product_type']
    if not p or any(k not in p for k in required):
        return flask.jsonify({"status": 400, "errors": f"Campos obrigatórios: {required}"}), 400

    # Validar travel_date se fornecido
    travel_date = p.get('travel_date')
    if travel_date:
        try:
            datetime.strptime(travel_date, "%Y-%m-%d")
        except ValueError:
            return flask.jsonify({"status": 400, "errors": "travel_date inválido (formato esperado: YYYY-MM-DD)"}), 400
    else:
        travel_date = datetime.now().strftime("%Y-%m-%d")

    conn = None
    try:
        conn = db_connection()
        cur = conn.cursor()

        # 1. Obter preço e tipo de bilhete
        cur.execute("""
            SELECT p.preco, t.tipobilheteid, t.categoria
            FROM preco p
            JOIN tipobilhete t ON p.tipobilhete_tipobilheteid = t.tipobilheteid
            WHERE (t.nome = %s OR t.categoria = %s)
              AND CURRENT_DATE BETWEEN p.datainicio AND p.datafim
            LIMIT 1
        """, (p['product_type'], p['product_type']))

        result = cur.fetchone()
        if not result:
            return flask.jsonify({"status": 400, "errors": "Tipo de bilhete inválido ou sem preço ativo"}), 400

        preco     = float(result[0])
        tipo_id   = result[1]
        categoria = result[2]

        # 2. Verificar que a linha existe
        cur.execute("SELECT linhaid FROM linha WHERE linhaid = %s", (p['line_id'],))
        if not cur.fetchone():
            return flask.jsonify({"status": 404, "errors": "Linha não encontrada"}), 404

        # 3. Verificar que existe viagem nessa linha na data indicada
        cur.execute("""
            SELECT viagemid FROM viagem
            WHERE linha_linhaid = %s
              AND DATE(datapartida) = %s::date
            LIMIT 1
        """, (p['line_id'], travel_date))

        if not cur.fetchone():
            return flask.jsonify({"status": 400, "errors": f"Não existe viagem para a linha {p['line_id']} na data {travel_date}"}), 400

        # 4. Verificar promoção ativa para esta linha + tipo
        cur.execute("""
            SELECT desconto FROM promocao
            WHERE linha_linhaid = %s
              AND tipobilhete_tipobilheteid = %s
              AND CURRENT_DATE BETWEEN datainicio AND datafim
            LIMIT 1
        """, (p['line_id'], tipo_id))

        promo = cur.fetchone()
        if promo:
            preco = round(preco * (1 - float(promo[0]) / 100), 2)

        # 5. INSERT na compra — o trigger debita o saldo automaticamente
        cur.execute("""
            INSERT INTO compra (datacompra, precofinal, estado, cliente_utilizador_utilizadorid, linha_linhaid)
            VALUES (CURRENT_TIMESTAMP, %s, 'Concluida', %s, %s)
            RETURNING compraid
        """, (preco, user_id, p['line_id']))
        compra_id = cur.fetchone()[0]

        # 6. Calcular validade conforme categoria do bilhete
        if 'monthly' in categoria.lower():
            validade = timedelta(days=30)
        elif 'daily' in categoria.lower():
            validade = timedelta(days=1)
        else:
            validade = timedelta(hours=4)   # single trip

        now        = datetime.now(timezone.utc)
        valido_ate = now + validade

        cur.execute("""
            INSERT INTO bilhete (validode, validoate, estado, tipobilhete_tipobilheteid, compra_compraid)
            VALUES (CURRENT_TIMESTAMP, %s, 'Valido', %s, %s)
            RETURNING bilheteid
        """, (valido_ate, tipo_id, compra_id))
        bilhete_id = cur.fetchone()[0]

        conn.commit()
        return flask.jsonify({
            "status": 200,
            "errors": None,
            "results": {
                "purchase_id": compra_id,
                "ticket_id":   bilhete_id,
                "final_price": preco
            }
        }), 200

    except Exception as e:
        if conn:
            conn.rollback()
