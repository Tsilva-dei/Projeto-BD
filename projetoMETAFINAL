##########################################################
## ENDPOINT 11 – VALIDATE / USE TICKET
## POST /dbproj/ticket/use/<ticket_id>
##########################################################

@app.route('/dbproj/ticket/use/<int:ticket_id>', methods=['POST'])
@client_required
def use_ticket(ticket_id):
    token = extract_token()
    data = jwt.decode(token, SECRET_KEY, algorithms=["HS256"])
    user_id = data['user_id']

    p = flask.request.get_json()
    if not p or 'used_at' not in p or 'station_id' not in p:
        return flask.jsonify({"status": 400, "errors": "Campos obrigatórios: used_at, station_id"}), 400

    conn = None
    try:
        conn = db_connection()
        cur = conn.cursor()

        # 1. Verificar que o bilhete pertence ao cliente e obter a linha
        cur.execute("""
            SELECT b.bilheteid, b.estado, b.validode, b.validoate, c.linha_linhaid
            FROM bilhete b
            JOIN compra c ON b.compra_compraid = c.compraid
            WHERE b.bilheteid = %s
              AND c.cliente_utilizador_utilizadorid = %s
            FOR UPDATE
        """, (ticket_id, user_id))

        bilhete = cur.fetchone()
        if not bilhete:
            return flask.jsonify({"status": 404, "errors": "Bilhete não encontrado ou não pertence ao utilizador"}), 404

        estado           = bilhete[1]
        valido_de        = bilhete[2]
        valido_ate       = bilhete[3]
        linha_do_bilhete = bilhete[4]

        if estado != 'Valido':
            return flask.jsonify({"status": 400, "errors": f"Bilhete não está válido (estado: {estado})"}), 400

        # Normalizar para naive datetime
        used_at_dt = datetime.strptime(p['used_at'], "%Y-%m-%d %H:%M:%S")

        if valido_de is not None and hasattr(valido_de, 'tzinfo') and valido_de.tzinfo is not None:
            valido_de = valido_de.replace(tzinfo=None)
        if valido_ate is not None and hasattr(valido_ate, 'tzinfo') and valido_ate.tzinfo is not None:
            valido_ate = valido_ate.replace(tzinfo=None)

        if not (valido_de <= used_at_dt <= valido_ate):
            return flask.jsonify({"status": 400, "errors": "Bilhete fora do período de validade"}), 400

        # 2. Verificar viagem disponível na mesma linha do bilhete
        cur.execute("""
            SELECT v.viagemid, v.ocupacaoatual, v.capacidademax
            FROM viagem v
            JOIN estacaolinha el ON v.linha_linhaid = el.linha_linhaid
            WHERE el.estacao_estacaoid = %s
              AND v.datapartida >= %s::timestamp
              AND v.linha_linhaid = %s
            ORDER BY v.datapartida ASC
            LIMIT 1
            FOR UPDATE OF v
        """, (p['station_id'], p['used_at'], linha_do_bilhete))

        viagem = cur.fetchone()
        if not viagem:
            return flask.jsonify({"status": 400, "errors": "Nenhuma viagem disponível nesta estação para a linha do seu bilhete"}), 400

        viagem_id, ocupacao, capacidade = viagem
        if ocupacao >= capacidade:
            return flask.jsonify({"status": 400, "errors": "Viagem sem capacidade disponível"}), 400

        # 3. Registar validação
        cur.execute("""
            INSERT INTO validacao (usadoa, estacao_estacaoid, bilhete_bilheteid, viagem_viagemid)
            VALUES (%s::timestamp, %s, %s, %s)
        """, (p['used_at'], p['station_id'], ticket_id, viagem_id))

        # 4. Incrementar ocupação
        cur.execute("""
            UPDATE viagem SET ocupacaoatual = ocupacaoatual + 1 WHERE viagemid = %s
        """, (viagem_id,))

        conn.commit()
        return flask.jsonify({"status": 200, "errors": None}), 200

    except Exception as e:
        if conn:
            conn.rollback()
        return flask.jsonify({"status": 400, "errors": str(e)}), 400
    finally:
        if conn:
            conn.close()

##########################################################
## ENDPOINT 12 – PEAK AND LOW DEMAND
## GET /dbproj/report/demand
##########################################################

@app.route('/dbproj/report/demand', methods=['GET'])
@admin_required
def report_demand():
    conn = None
    try:
        conn = db_connection()
        cur = conn.cursor()

        cur.execute("""
            SELECT h1.line_id, h1.time_slot, h1.validations
            FROM (
                SELECT
                    viagem.linha_linhaid AS line_id,
                    to_char(v.usadoa, 'HH24') || ':00-' || to_char(v.usadoa, 'HH24') || ':59' AS time_slot,
                    COUNT(*) AS validations
                FROM validacao v
                JOIN viagem ON v.viagem_viagemid = viagem.viagemid
                GROUP BY viagem.linha_linhaid,
                         to_char(v.usadoa, 'HH24') || ':00-' || to_char(v.usadoa, 'HH24') || ':59'
            ) h1
            WHERE h1.validations = (
                SELECT MAX(sub.validations)
                FROM (
                    SELECT COUNT(*) AS validations
                    FROM validacao v2
                    JOIN viagem vv2 ON v2.viagem_viagemid = vv2.viagemid
                    WHERE vv2.linha_linhaid = h1.line_id
                    GROUP BY to_char(v2.usadoa, 'HH24')
                ) sub
            )
            OR h1.validations = (
                SELECT MIN(sub.validations)
                FROM (
                    SELECT COUNT(*) AS validations
                    FROM validacao v3
                    JOIN viagem vv3 ON v3.viagem_viagemid = vv3.viagemid
                    WHERE vv3.linha_linhaid = h1.line_id
                    GROUP BY to_char(v3.usadoa, 'HH24')
                ) sub
            )
            ORDER BY h1.line_id, h1.validations DESC
        """)

        results = [{"line_id": r[0], "time_slot": r[1], "validations": r[2]} for r in cur.fetchall()]
        return flask.jsonify({"status": 200, "errors": None, "results": results}), 200

    except Exception as e:
        return flask.jsonify({"status": 500, "errors": str(e)}), 500
    finally:
        if conn:
            conn.close()

##########################################################
## ENDPOINT 13 – TOP SPENDERS BY LINE
## GET /dbproj/report/top_spenders
##########################################################

@app.route('/dbproj/report/top_spenders', methods=['GET'])
@admin_required
def report_top_spenders():
    conn = None
    try:
        conn = db_connection()
        cur = conn.cursor()

        cur.execute("""
            SELECT base.line_id, base.customer_id, base.customer_name, base.spent
            FROM (
                SELECT
                    compras_por_linha.line_id,
                    compras_por_linha.customer_id,
                    compras_por_linha.customer_name,
                    SUM(compras_por_linha.precofinal) AS spent
                FROM (
                    SELECT DISTINCT
                        vv.linha_linhaid                          AS line_id,
                        c.cliente_utilizador_utilizadorid         AS customer_id,
                        u.nome                                    AS customer_name,
                        c.compraid,
                        c.precofinal
                    FROM validacao val
                    JOIN viagem vv   ON val.viagem_viagemid   = vv.viagemid
                    JOIN bilhete b   ON val.bilhete_bilheteid  = b.bilheteid
                    JOIN compra c    ON b.compra_compraid      = c.compraid
                    JOIN utilizador u ON c.cliente_utilizador_utilizadorid = u.utilizadorid
                    WHERE c.datacompra >= CURRENT_DATE - INTERVAL '30 days'
                ) compras_por_linha
                GROUP BY compras_por_linha.line_id,
                         compras_por_linha.customer_id,
                         compras_por_linha.customer_name
            ) base
            WHERE base.spent = (
                SELECT MAX(inner_base.spent)
                FROM (
                    SELECT SUM(inner_dist.precofinal) AS spent
                    FROM (
                        SELECT DISTINCT
                            vv2.linha_linhaid                      AS line_id,
                            c2.cliente_utilizador_utilizadorid     AS customer_id,
                            c2.compraid,
                            c2.precofinal
                        FROM validacao val2
                        JOIN viagem vv2  ON val2.viagem_viagemid   = vv2.viagemid
                        JOIN bilhete b2  ON val2.bilhete_bilheteid  = b2.bilheteid
                        JOIN compra c2   ON b2.compra_compraid      = c2.compraid
                        WHERE c2.datacompra >= CURRENT_DATE - INTERVAL '30 days'
                          AND vv2.linha_linhaid = base.line_id
                    ) inner_dist
                    GROUP BY inner_dist.customer_id
                ) inner_base
            )
            ORDER BY base.line_id, base.customer_id
        """)

        results = [
            {"line_id": r[0], "customer_id": r[1], "customer_name": r[2], "spent": float(r[3])}
            for r in cur.fetchall()
        ]
        return flask.jsonify({"status": 200, "errors": None, "results": results}), 200

    except Exception as e:
        return flask.jsonify({"status": 500, "errors": str(e)}), 500
    finally:
        if conn:
            conn.close()

