def extract_token():
    header = flask.request.headers.get('Authorization')
    if not header:
        return None
    parts = header.split()
    if len(parts) != 2:
        return None
    return parts[1]

def admin_required(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        token = extract_token()
        if not token:
            return flask.jsonify({"status": 401, "errors": "Token em falta"}), 401
        try:
            data = jwt.decode(token, SECRET_KEY, algorithms=["HS256"])
            if data['role'] not in ['admin', 'super_admin']:
                return flask.jsonify({"status": 403, "errors": "Requer privilégios de Admin"}), 403
        except jwt.ExpiredSignatureError:
            return flask.jsonify({"status": 401, "errors": "Token expirado"}), 401
        except jwt.InvalidTokenError:
            return flask.jsonify({"status": 401, "errors": "Token inválido"}), 401
        return f(*args, **kwargs)
    return decorated

def super_admin_required(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        token = extract_token()
        if not token:
            return flask.jsonify({"status": 401, "errors": "Token em falta"}), 401
        try:
            data = jwt.decode(token, SECRET_KEY, algorithms=["HS256"])
            if data['role'] != 'super_admin':
                return flask.jsonify({"status": 403, "errors": "Apenas o Super Admin pode fazer isto"}), 403
        except jwt.ExpiredSignatureError:
            return flask.jsonify({"status": 401, "errors": "Token expirado"}), 401
        except jwt.InvalidTokenError:
            return flask.jsonify({"status": 401, "errors": "Não autorizado"}), 401
        return f(*args, **kwargs)
    return decorated

def client_required(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        token = extract_token()
        if not token:
            return flask.jsonify({"status": 401, "errors": "Token em falta"}), 401
        try:
            data = jwt.decode(token, SECRET_KEY, algorithms=["HS256"])
            if data['role'] != 'client':
                return flask.jsonify({"status": 403, "errors": "Apenas clientes podem fazer isto"}), 403
        except jwt.ExpiredSignatureError:
            return flask.jsonify({"status": 401, "errors": "Token expirado"}), 401
        except jwt.InvalidTokenError:
            return flask.jsonify({"status": 401, "errors": "Token inválido"}), 401
        return f(*args, **kwargs)
    return decorated

