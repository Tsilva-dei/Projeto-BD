from functools import wraps

# Guarda para Admins (ou Super Admins)
def admin_required(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        token_header = flask.request.headers.get('Authorization')
        if not token_header:
            return flask.jsonify({"status": 401, "errors": "Token em falta"}), 401
        token = token_header.split(" ")[1] if "Bearer" in token_header else token_header
        try:
            data = jwt.decode(token, SECRET_KEY, algorithms=["HS256"])
            if data['role'] not in ['admin', 'super_admin']:
                return flask.jsonify({"status": 403, "errors": "Requer privilégios de Admin"}), 403
        except:
            return flask.jsonify({"status": 401, "errors": "Token inválido"}), 401
        return f(*args, **kwargs)
    return decorated

# Guarda APENAS para Super Admins
def super_admin_required(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        token_header = flask.request.headers.get('Authorization')
        token = token_header.split(" ")[1] if token_header and "Bearer" in token_header else token_header
        try:
            data = jwt.decode(token, SECRET_KEY, algorithms=["HS256"])
            if data['role'] != 'super_admin':
                return flask.jsonify({"status": 403, "errors": "Apenas o Super Admin pode fazer isto"}), 403
        except:
            return flask.jsonify({"status": 401, "errors": "Não autorizado"}), 401
        return f(*args, **kwargs)
    return decorated



