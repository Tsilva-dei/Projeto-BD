## ENDPOINT 14 – MONTHLY REPORT
## GET /dbproj/report/monthly
##########################################################

@app.route('/dbproj/report/monthly', methods=['GET'])
@admin_required
def report_monthly():
    conn = None
    try:
        conn = db_connection()
        cur = conn.cursor()

        cur.execute("""
            SELECT
                t.line_id,
                t.month,
                COUNT(t.customer_id)                                    AS active_customers,
                SUM(CASE WHEN t.validations >= 2 THEN 1 ELSE 0 END)    AS repeat_customers
            FROM (
                SELECT
                    vv.linha_linhaid                                AS line_id,
                    EXTRACT(MONTH FROM val.usadoa)                  AS month,
                    c.cliente_utilizador_utilizadorid               AS customer_id,
                    COUNT(val.validacaoid)                          AS validations
                FROM validacao val
                JOIN viagem vv  ON val.viagem_viagemid  = vv.viagemid
                JOIN bilhete b  ON val.bilhete_bilheteid = b.bilheteid
                JOIN compra c   ON b.compra_compraid     = c.compraid
                GROUP BY vv.linha_linhaid,
                         EXTRACT(MONTH FROM val.usadoa),
                         c.cliente_utilizador_utilizadorid
            ) t
            GROUP BY t.line_id, t.month
            ORDER BY t.line_id, t.month
        """)

        results = [
            {"line_id": r[0], "month": int(r[1]), "active_customers": r[2], "repeat_customers": int(r[3])}
            for r in cur.fetchall()
        ]
        return flask.jsonify({"status": 200, "errors": None, "results": results}), 200

    except Exception as e:
        return flask.jsonify({"status": 500, "errors": str(e)}), 500
    finally:
        if conn:
            conn.close()

