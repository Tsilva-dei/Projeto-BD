        return flask.jsonify({
            "status": 400,
            "errors": "Campo 'open' é obrigatório"
        }), 400

    conn = db_connection()
    cur = conn.cursor()

    try:

        ####################################################
        # atualizar estado da linha
        ####################################################

        cur.execute("""
            UPDATE linha
            SET aberta = %s
            WHERE linhaid = %s
        """, (p['open'], line_id))

        ####################################################
        # linha não encontrada
        ####################################################

        if cur.rowcount == 0:
            return flask.jsonify({
                "status": 404,
                "errors": "Linha não encontrada"
            }), 404

        ####################################################
