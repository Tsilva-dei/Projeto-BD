@app.route('/dbproj/report/top_spenders', methods=['GET'])
@admin_required
def report_top_spenders():
    conn = db_connection()
    cur = conn.cursor()
    try:
        query = """
        SELECT base.line_id, base.customer_id, base.customer_name, base.spent
        FROM (
            SELECT line_id, customer_id, customer_name, SUM(precofinal) AS spent
            FROM (
                SELECT DISTINCT
                    viagem.linha_linhaid AS line_id,
                    compra.compraid,
                    compra.cliente_utilizador_utilizadorid AS customer_id,
                    u.nome AS customer_name,
                    compra.precofinal
                FROM validacao v
                JOIN viagem ON v.viagem_viagemid = viagem.viagemid
                JOIN bilhete b ON v.bilhete_bilheteid = b.bilheteid
                JOIN compra ON b.compra_compraid = compra.compraid
                JOIN utilizador u ON compra.cliente_utilizador_utilizadorid = u.utilizadorid
                WHERE compra.datacompra >= CURRENT_DATE - INTERVAL '30 days'
            ) dist
            GROUP BY line_id, customer_id, customer_name
        ) base
        WHERE base.spent = (
            SELECT MAX(inner_sum.spent)
            FROM (
                SELECT SUM(precofinal) AS spent
                FROM (
                    SELECT DISTINCT
                        viagem.linha_linhaid AS line_id,
                        compra.compraid,
                        compra.cliente_utilizador_utilizadorid AS customer_id,
                        compra.precofinal
                    FROM validacao v
                    JOIN viagem ON v.viagem_viagemid = viagem.viagemid
                    JOIN bilhete b ON v.bilhete_bilheteid = b.bilheteid
                    JOIN compra ON b.compra_compraid = compra.compraid
                    WHERE compra.datacompra >= CURRENT_DATE - INTERVAL '30 days'
                ) inner_dist
                WHERE inner_dist.line_id = base.line_id
                GROUP BY inner_dist.customer_id
            ) inner_sum
        )
        ORDER BY base.line_id
        """
        cur.execute(query)
        results = [{"line_id": r[0], "customer_id": r[1], "customer_name": r[2], "spent": float(r[3])} for r in cur.fetchall()]
        return flask.jsonify({"status": 200, "errors": None, "results": results}), 200
    except Exception as e:
        return flask.jsonify({"status": 500, "errors": str(e)}), 500
    finally:
        conn.close()

