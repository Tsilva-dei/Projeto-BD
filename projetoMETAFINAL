            "status": 200,
            "errors": None,
            "results": f"Linha {line_id} foi {estado} com sucesso"
        }), 200

    except Exception as e:

        conn.rollback()

        return flask.jsonify({
            "status": 500,
            "errors": str(e)
        }), 500

    finally:
        conn.close()
