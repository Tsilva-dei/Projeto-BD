@app.route('/dbproj/lines_next', methods=['GET'])
def get_lines_next():
    conn = db_connection()
    cur = conn.cursor()
    try:
        query = """
            SELECT DISTINCT ON (l.linhaid, v.sentido)
                l.linhaid,
                l.nome,
                v.sentido,
                v.datapartida,
                v.capacidademax - v.ocupacaoatual AS available_capacity
            FROM linha l
            JOIN viagem v ON l.linhaid = v.linha_linhaid
            WHERE v.datapartida >= CURRENT_TIMESTAMP
            ORDER BY l.linhaid, v.sentido, v.datapartida ASC
        """
        cur.execute(query)
        rows = cur.fetchall()

        results = []
        for row in rows:
            results.append({
                "line_id": row[0],
                "line_name": row[1],
                "destination_terminal": row[2],
                "departure_time": row[3].strftime("%Y-%m-%d %H:%M:%S"),
                "estimated_delay_min": 0,
                "available_capacity": int(row[4])
            })

        return flask.jsonify({"status": 200, "errors": None, "results": results}), 200
        
    except Exception as e:
        return flask.jsonify({"status": 500, "errors": str(e)}), 500
    finally:
        if conn is not None: conn.close()

