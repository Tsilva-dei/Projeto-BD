@app.route('/dbproj/user', methods=['PUT'])
def login():
    payload = flask.request.get_json()
    email    = (payload.get('username') or payload.get('email')) if payload else None
    password = payload.get('password') if payload else None
    if not email or not password:
        return flask.jsonify({"status": 400, "errors": "Faltam dados (username, password)"}), 400

    conn = None
    try:
        conn = db_connection()
        cur = conn.cursor()

        cur.execute("""
            SELECT u.utilizadorid, u.nome,
                   CASE
                       WHEN a.super = TRUE THEN 'super_admin'
                       WHEN a.utilizador_utilizadorid IS NOT NULL THEN 'admin'
                       WHEN c.utilizador_utilizadorid IS NOT NULL THEN 'client'
                       ELSE 'user'
                   END AS role
            FROM utilizador u
            LEFT JOIN admin a ON u.utilizadorid = a.utilizador_utilizadorid
            LEFT JOIN cliente c ON u.utilizadorid = c.utilizador_utilizadorid
            WHERE u.email = %s AND u.palavrapasse = %s
        """, (email, password))

        user = cur.fetchone()
        if not user:
            return flask.jsonify({"status": 401, "errors": "Credenciais erradas"}), 401

        token = jwt.encode({
            'user_id': user[0],
            'role': user[2],
            'exp': datetime.now(timezone.utc) + timedelta(hours=4)
        }, SECRET_KEY, algorithm="HS256")

        return flask.jsonify({"status": 200, "errors": None, "results": {"token": token, "role": user[2]}}), 200

    except Exception as e:
        logger.error(f'Login error: {e}')
        return flask.jsonify({"status": 500, "errors": str(e)}), 500
    finally:
        if conn:
            conn.close()

