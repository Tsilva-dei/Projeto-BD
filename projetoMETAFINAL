@app.route('/dbproj/register/admin', methods=['PUT'])
@super_admin_required
def register_admin():
    p = flask.request.get_json()
    conn = db_connection()
    cur = conn.cursor()
    try:
        cur.execute("INSERT INTO utilizador (nome, email, palavrapasse) VALUES (%s,%s,%s) RETURNING utilizadorid",
                    (p['nome'], p['email'], p['password']))
        uid = cur.fetchone()[0]
        # super=False porque um admin novo não nasce super admin por defeito
        cur.execute("INSERT INTO admin (super, numerofuncionario, utilizador_utilizadorid) VALUES (FALSE, %s, %s)",
                    (p['num_func'], uid))
        conn.commit()
        return flask.jsonify({"status": 201, "results": "Novo Administrador criado"}), 201
    except Exception as e:
        conn.rollback()
        return flask.jsonify({"status": 400, "errors": str(e)}), 400
    finally: conn.close()


@app.route('/dbproj/notices/broadcast', methods=['POST'])
@admin_required # Só admins criam avisos
def create_notice():
    p = flask.request.get_json()
    conn = db_connection()
    cur = conn.cursor()
    try:
        # 1. Inserir o aviso
        # Nota: admin_id deve vir do token para saber quem criou
        token = flask.request.headers.get('Authorization').split(" ")[1]
        data = jwt.decode(token, SECRET_KEY, algorithms=["HS256"])
        admin_id = data['user_id']

        cur.execute("""
            INSERT INTO aviso (titulo, mensagem, datacriacao, avisoglobal, admin_utilizador_utilizadorid)
            VALUES (%s, %s, CURRENT_DATE, %s, %s) RETURNING avisoid
        """, (p['titulo'], p['mensagem'], p['global'], admin_id))
        
        aviso_id = cur.fetchone()[0]

        # 2. Se NÃO for global, associar ao cliente específico
        if not p['global'] and 'cliente_id' in p:
            cur.execute("""
                INSERT INTO clienteaviso (lido, aviso_avisoid, cliente_utilizador_utilizadorid)
                VALUES (FALSE, %s, %s)
            """, (aviso_id, p['cliente_id']))

        conn.commit()
        return flask.jsonify({"status": 201, "results": "Aviso criado com sucesso"}), 201
    except Exception as e:
        conn.rollback()
        return flask.jsonify({"status": 400, "errors": str(e)}), 400
    finally: conn.close()


@app.route('/dbproj/line_operation/<int:line_id>', methods=['PUT'])
@admin_required
def update_line_operation(line_id):
    p = flask.request.get_json()
    conn = db_connection()
    cur = conn.cursor()
    try:
        query = """
            UPDATE linha 
            SET horaabertura = CURRENT_DATE + %s::time, 
                horafechar = CURRENT_DATE + %s::time, 
                frequenciamin = %s
            WHERE linhaid = %s
        """
        cur.execute(query, (p['start_time'], p['end_time'], p['frequency_minutes'], line_id))
        
        # Se nenhuma linha foi alterada (ex: linha 99 não existe)
        if cur.rowcount == 0:
            return flask.jsonify({"status": 404, "errors": "Linha não encontrada"}), 404

        conn.commit()
        return flask.jsonify({"status": 200, "errors": None}), 200
        
    except Exception as e:
        conn.rollback()
        return flask.jsonify({"status": 400, "errors": str(e)}), 400
    finally: 
        conn.close()
