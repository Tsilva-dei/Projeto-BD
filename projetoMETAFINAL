        cur.execute("SELECT tipobilheteid FROM tipobilhete WHERE tipobilheteid = %s", (fare_id,))
        if not cur.fetchone():
            return flask.jsonify({"status": 404, "errors": "Tipo de bilhete não encontrado"}), 404

        cur.execute("""
            UPDATE preco
            SET datafim = %s::date - INTERVAL '1 day'
            WHERE tipobilhete_tipobilheteid = %s
              AND datafim >= CURRENT_DATE
        """, (p['effective_from'], fare_id))

        cur.execute("""
            INSERT INTO preco (preco, datainicio, datafim, tipobilhete_tipobilheteid)
            VALUES (%s, %s::date, '2099-12-31', %s)
        """, (p['price'], p['effective_from'], fare_id))

        conn.commit()
        return flask.jsonify({"status": 200, "errors": None}), 200

    except Exception as e:
        if conn:
            conn.rollback()
        return flask.jsonify({"status": 400, "errors": str(e)}), 400
