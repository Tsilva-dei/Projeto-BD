@app.route('/dbproj/line_operation/<int:line_id>', methods=['PUT'])
@admin_required
def update_line_operation(line_id):
    p = flask.request.get_json()
    required = ['start_time', 'end_time', 'frequency_minutes']
    if not p or any(k not in p for k in required):
        return flask.jsonify({"status": 400, "errors": f"Campos obrigatórios: {required}"}), 400

    conn = None
    try:
        conn = db_connection()
        cur = conn.cursor()

        cur.execute("""
            UPDATE linha
            SET horaabertura  = CURRENT_DATE + %s::time,
                horafechar    = CURRENT_DATE + %s::time,
                frequenciamin = %s
            WHERE linhaid = %s
        """, (p['start_time'], p['end_time'], p['frequency_minutes'], line_id))

        if cur.rowcount == 0:
            conn.rollback()
            return flask.jsonify({"status": 404, "errors": "Linha não encontrada"}), 404

        if 'vehicle_capacity' in p:
            cur.execute("""
                UPDATE viagem
                SET capacidademax = %s
                WHERE linha_linhaid = %s
                  AND datapartida >= CURRENT_TIMESTAMP
                  AND ocupacaoatual <= %s
            """, (p['vehicle_capacity'], line_id, p['vehicle_capacity']))

        conn.commit()
        return flask.jsonify({"status": 200, "errors": None}), 200

    except Exception as e:
        if conn:
            conn.rollback()
        return flask.jsonify({"status": 400, "errors": str(e)}), 400
    finally:
        if conn:
            conn.close()

