CREATE TABLE estacao (
	estacaoid BIGINT NOT NULL,
	nome	 VARCHAR(512) NOT NULL,
	PRIMARY KEY(estacaoid)
);

CREATE TABLE estacaolinha (
	ordem		 BIGINT NOT NULL,
	linha_linhaid	 BIGINT,
	estacao_estacaoid BIGINT,
	PRIMARY KEY(linha_linhaid,estacao_estacaoid)
);

CREATE TABLE utilizador (
	utilizadorid BIGINT NOT NULL,
	nome	 VARCHAR(512) NOT NULL,
	email	 VARCHAR(512) NOT NULL,
	palavrapasse VARCHAR(512) NOT NULL,
	PRIMARY KEY(utilizadorid)
);

CREATE TABLE cliente (
	saldo			 FLOAT(8) NOT NULL,
	nif			 VARCHAR(512) NOT NULL,
	telemovel		 VARCHAR(512) NOT NULL,
	idade			 INTEGER NOT NULL,
	utilizador_utilizadorid BIGINT NOT NULL,
	PRIMARY KEY(utilizador_utilizadorid)
);

CREATE TABLE viagem (
	viagemid	 BIGINT NOT NULL,
	datapartida	 TIMESTAMP NOT NULL,
	capacidademax BIGINT NOT NULL,
	sentido	 VARCHAR(512) NOT NULL,
	ocupacaoatual BIGINT NOT NULL,
	linha_linhaid BIGINT NOT NULL,
	PRIMARY KEY(viagemid)
);

CREATE TABLE bilhete (
	bilheteid		 BIGINT NOT NULL,
	validode			 TIMESTAMP,
	validoate		 TIMESTAMP,
	estado			 VARCHAR(512) NOT NULL,
	tipobilhete_tipobilheteid BIGINT NOT NULL,
	compra_compraid		 BIGINT NOT NULL,
	PRIMARY KEY(bilheteid)
);

CREATE TABLE compra (
	compraid			 BIGINT NOT NULL,
	datacompra			 TIMESTAMP NOT NULL,
	precofinal			 FLOAT(8) NOT NULL,
	estado				 VARCHAR(512) NOT NULL,
	linha_linhaid			 BIGINT NOT NULL,
	cliente_utilizador_utilizadorid BIGINT NOT NULL,
	PRIMARY KEY(compraid)
);

CREATE TABLE preco (
	precoid			 BIGINT NOT NULL,
	preco			 FLOAT(8) NOT NULL,
	datainicio		 DATE NOT NULL,
	datafim			 DATE NOT NULL,
	tipobilhete_tipobilheteid BIGINT,
	PRIMARY KEY(precoid,tipobilhete_tipobilheteid)
);

CREATE TABLE linha (
	linhaid	 BIGINT NOT NULL,
	nome		 VARCHAR(512) NOT NULL,
	frequenciamin INTEGER NOT NULL,
	aberta	 BOOL NOT NULL,
	horaabertura	 TIMESTAMP NOT NULL,
	horafechar	 TIMESTAMP NOT NULL,
	PRIMARY KEY(linhaid)
);

CREATE TABLE promocao (
	promocaoid		 BIGINT NOT NULL,
	desconto			 BIGINT NOT NULL,
	datainicio		 DATE NOT NULL,
	datafim			 DATE NOT NULL,
	nome			 VARCHAR(512) NOT NULL,
	tipobilhete_tipobilheteid BIGINT NOT NULL,
	linha_linhaid		 BIGINT NOT NULL,
	PRIMARY KEY(promocaoid)
);

CREATE TABLE validacao (
	validacaoid	 BIGINT NOT NULL,
	usadoa		 TIMESTAMP NOT NULL,
	estacao_estacaoid BIGINT NOT NULL,
	bilhete_bilheteid BIGINT NOT NULL,
	viagem_viagemid	 BIGINT NOT NULL,
	PRIMARY KEY(validacaoid)
);

CREATE TABLE transacao (
	transacaoid			 BIGINT NOT NULL,
	valor				 FLOAT(8) NOT NULL,
	tipotransacao			 VARCHAR(512) NOT NULL,
	datatransacao			 TIMESTAMP NOT NULL,
	estado				 VARCHAR(512) NOT NULL,
	cliente_utilizador_utilizadorid BIGINT NOT NULL,
	PRIMARY KEY(transacaoid)
);

CREATE TABLE aviso (
	avisoid			 BIGINT NOT NULL,
	titulo			 VARCHAR(512) NOT NULL,
	mensagem			 VARCHAR(512) NOT NULL,
	datacriacao			 DATE NOT NULL,
	avisoglobal			 BOOL NOT NULL,
	admin_utilizador_utilizadorid BIGINT NOT NULL,
	PRIMARY KEY(avisoid)
);

CREATE TABLE clienteaviso (
	lido				 BOOL NOT NULL DEFAULT False,
	aviso_avisoid			 BIGINT,
	cliente_utilizador_utilizadorid BIGINT,
	PRIMARY KEY(aviso_avisoid,cliente_utilizador_utilizadorid)
);

CREATE TABLE tipobilhete (
	tipobilheteid BIGINT NOT NULL,
	nome		 VARCHAR(512) NOT NULL,
	categoria	 VARCHAR(512) NOT NULL,
	PRIMARY KEY(tipobilheteid)
);

CREATE TABLE admin (
	super			 BOOL NOT NULL,
	numerofuncionario	 BIGINT NOT NULL,
	utilizador_utilizadorid BIGINT NOT NULL,
	PRIMARY KEY(utilizador_utilizadorid)
);

CREATE TABLE compra_transacao (
	compra_compraid	 BIGINT NOT NULL,
	transacao_transacaoid BIGINT,
	PRIMARY KEY(transacao_transacaoid)
);

