-- Criar a tabela de auditoria
CREATE TABLE IF NOT EXISTS log_admin_creation (
    logid SERIAL PRIMARY KEY,
    admin_criado_id BIGINT,
    data_criacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Criar a função 
CREATE OR REPLACE FUNCTION audit_admin_creation()
RETURNS TRIGGER AS $$
BEGIN
    INSERT INTO log_admin_creation (admin_criado_id)
    VALUES (NEW.utilizador_utilizadorid);
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- CRIAR O TRIGGER 
DROP TRIGGER IF EXISTS trg_audit_admin ON admin;
CREATE TRIGGER trg_audit_admin
AFTER INSERT ON admin
FOR EACH ROW
EXECUTE FUNCTION audit_admin_creation();

